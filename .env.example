# 1. Telegram (エスカレーション・教育用)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CEO_CHAT_ID=

# 2. LINE (スタッフ相談窓口)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# 3. Notion (スタッフ日報DB)
NOTION_BOT_TOKEN=
NOTION_DATABASE_ID=

# 4. Supabase (ナレッジ・設定・ログDB)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# 5. Core AI (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key

# 6. システム設定
PORT=3000
